# API authentication token (make this long and complex)
TOKEN=your-very-complex-api-key-here

# Background removal model
# birefnet-portrait — highest quality, larger model (~973MB), may be slower
# isnet-general-use — lighter (~170MB), faster, more stable on some VMs
REMBG_MODEL=birefnet-portrait

# Cleanup: how old a folder must be before deletion (minutes)
CLEANUP_AGE_MINUTES=5

# Cleanup: how often the scheduler runs (minutes)
CLEANUP_INTERVAL_MINUTES=5

# Rate limiting: max requests per window per email
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_MINUTES=1

# Job expiry: how long job records stay in memory (minutes)
JOB_EXPIRY_MINUTES=10
